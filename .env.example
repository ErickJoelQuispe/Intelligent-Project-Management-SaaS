# Copiar este archivo como .env y ajustar los valores localmente.
# .env está en .gitignore — nunca lo commitees.

# ─── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme

# ─── Keycloak ────────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=admin

# ─── Kafka ───────────────────────────────────────────────────────
# Generá un ID único para tu cluster con:
#   docker run --rm confluentinc/cp-kafka:7.7.1 kafka-storage random-uuid
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# ─── Auth Service / Service Template / Task Service ─────────────
# DB_PASSWORD is used by auth-service, service-template, task-service, and any service derived from them.
DB_PASSWORD=
KEYCLOAK_CLIENT_SECRET=change-me-get-from-keycloak-admin

# ─── AI Service ──────────────────────────────────────────────────
# Get your API key from https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here
