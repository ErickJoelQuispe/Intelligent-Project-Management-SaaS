{
  "uid": "epm-jvm-overview",
  "title": "JVM Overview",
  "description": "JVM heap, GC, threads, and CPU metrics per service",
  "tags": ["jvm", "java", "observability"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource",
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "service",
        "type": "query",
        "datasource": "${datasource}",
        "query": "label_values(jvm_memory_used_bytes, application)",
        "label": "Service",
        "hide": 0,
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": "${datasource}",
        "query": "label_values(jvm_memory_used_bytes{application=\"$service\"}, instance)",
        "label": "Instance",
        "hide": 0,
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Heap Used vs Max",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": "${datasource}",
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"$service\", instance=~\"$instance\", area=\"heap\"}",
          "legendFormat": "Heap Used - {{id}}",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{application=\"$service\", instance=~\"$instance\", area=\"heap\"}",
          "legendFormat": "Heap Max - {{id}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "GC Pause Duration",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": "${datasource}",
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"$service\", instance=~\"$instance\"}[5m])",
          "legendFormat": "GC Pause Rate - {{cause}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 3,
      "title": "Live Threads",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": "${datasource}",
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"$service\", instance=~\"$instance\"}",
          "legendFormat": "Live Threads",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"$service\", instance=~\"$instance\"}",
          "legendFormat": "Daemon Threads",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 4,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": "${datasource}",
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"$service\", instance=~\"$instance\"}",
          "legendFormat": "Process CPU",
          "refId": "A"
        },
        {
          "expr": "system_cpu_usage{application=\"$service\", instance=~\"$instance\"}",
          "legendFormat": "System CPU",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2 }
        }
      }
    }
  ]
}
