{
  "uid": "epm-circuit-breakers",
  "title": "Circuit Breakers",
  "description": "Resilience4j circuit breaker states and call statistics",
  "tags": ["resilience4j", "circuit-breaker", "observability"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource",
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "service",
        "type": "query",
        "datasource": "${datasource}",
        "query": "label_values(resilience4j_circuitbreaker_state, application)",
        "label": "Service",
        "hide": 0,
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "name",
        "type": "query",
        "datasource": "${datasource}",
        "query": "label_values(resilience4j_circuitbreaker_state{application=~\"$service\"}, name)",
        "label": "Circuit Breaker",
        "hide": 0,
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Circuit Breaker State",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": "${datasource}",
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_state{application=~\"$service\", name=~\"$name\"}",
          "legendFormat": "{{application}} / {{name}} — {{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "OPEN", "color": "red" } } },
            { "type": "value", "options": { "2": { "text": "HALF_OPEN", "color": "yellow" } } }
          ],
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "Circuit Breaker Calls",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": "${datasource}",
      "targets": [
        {
          "expr": "rate(resilience4j_circuitbreaker_calls_seconds_count{application=~\"$service\", name=~\"$name\"}[5m])",
          "legendFormat": "{{application}} / {{name}} — {{kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 3,
      "title": "Circuit Breaker Failures",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": "${datasource}",
      "targets": [
        {
          "expr": "rate(resilience4j_circuitbreaker_calls_seconds_count{application=~\"$service\", name=~\"$name\", kind=\"failed\"}[5m])",
          "legendFormat": "Failed - {{application}} / {{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "custom": { "lineWidth": 2 }
        }
      }
    }
  ]
}
